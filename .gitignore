# ---------------------------------------------------------------
# Unity generated folders (never commit these)
# ---------------------------------------------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Visual Studio / Rider / VS Code project files
.vs/
.idea/
.vsconfig
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D build / crash reports
sysinfo.txt
*.apk
*.aab
*.unitypackage
*.app
crashlytics-build.properties

# Gradle cache
.gradle/

# OS files
.DS_Store
Thumbs.db

# ---------------------------------------------------------------
# IDE solution files (new XML-based format)
# ---------------------------------------------------------------
*.slnx

# ---------------------------------------------------------------
# Unity crash-recovery scenes (auto-generated)
# ---------------------------------------------------------------
**/[Aa]ssets/_Recovery/
**/[Aa]ssets/_Recovery.meta

# ---------------------------------------------------------------
# Google External Dependency Manager (EDM4U) - reimportable plugin
# ---------------------------------------------------------------
**/[Aa]ssets/MobileDependencyResolver/
**/[Aa]ssets/MobileDependencyResolver.meta

# ---------------------------------------------------------------
# Unity IAP / Billing auto-generated catalog
# ---------------------------------------------------------------
**/[Aa]ssets/Resources/BillingMode.json
**/[Aa]ssets/Resources/BillingMode.json.meta
**/[Aa]ssets/Resources.meta

# ---------------------------------------------------------------
# Unity Package Manager local settings (regenerated per machine)
# ---------------------------------------------------------------
**/[Pp]roject[Ss]ettings/PackageManagerSettings.asset

# ---------------------------------------------------------------
# PaladinSetup diagnostic log (editor build trace, machine-local)
# ---------------------------------------------------------------
**/PaladinSetup.log
