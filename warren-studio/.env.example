# ---- Warren's Game Studio config -----------------------------------------
# Copy to a local mechanism and set before running. Never commit real secrets.

# Port the server listens on (Container Apps injects this automatically).
PORT=8080

# Signs the session cookie. REQUIRED in production — set to a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# How long a login stays valid while idle, in minutes.
SESSION_IDLE_MIN=120

# ---- GitHub OAuth login (PRIMARY front door) ------------------------------
# The interactive "Sign in with GitHub" flow. This is BOTH the studio's login
# gate AND the credential used to commit & push as the signed-in human (so
# Warren's pushes are attributed to his own GitHub identity, not a shared bot).
#
# Create a classic OAuth App at https://github.com/settings/developers
#   - Homepage URL:           your deployed studio URL
#   - Authorization callback:  <studio-url>/auth/github/callback
# then paste its client id + secret here. When both are set, the login page
# shows the "Sign in with GitHub" button. This is the ONLY way to log in.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Comma-separated GitHub logins allowed to sign in. CLOSED BY DEFAULT — if this
# is empty, NOBODY can log in via GitHub. List exactly the people you trust.
GITHUB_OAUTH_ALLOWED_USERS=jorgecotillo,warren-github-login

# Optional explicit callback URL. Leave blank to derive it from the request
# (works behind Azure's TLS proxy via trust proxy). Set it only if the public
# URL differs from what the app sees.
# GITHUB_OAUTH_CALLBACK_URL=https://your-studio.azurewebsites.net/auth/github/callback

# Optional OAuth scope. Default below is enough to read identity and push code.
# GITHUB_OAUTH_SCOPE=repo read:user user:email

# ---- Repo location ---------------------------------------------------------
# Where the csharp_unity_tutoring checkout lives. Defaults to two levels up
# from warren-studio/ (i.e. the repo root) when unset. In a container, point
# this at the mounted/cloned repo, e.g. /repo.
# REPO_ROOT=/repo

# ---- Copilot chat (Phase 2) ------------------------------------------------
# Model the chat assistant uses. Higher tiers consume premium requests from
# your Copilot allowance.
CHAT_MODEL=claude-sonnet-4.6

# Max chat messages per user, per hour. Protects your Copilot subscription
# from runaway loops.
CHAT_RATE_PER_HOUR=60

# ---- See-the-change pipeline (Phase 3/4) -----------------------------------
# Where the CI-built WebGL bundle is published inside the repo. In production
# the GitHub Actions WebGL workflow commits the playable build into docs/game,
# and the portal serves /game from there. Locally you can leave this unset to
# preview a local Editor build under mvp_v1/Builds/WebGL instead.
GAME_BUILD_DIR=docs/game

# When "on", the AI's code edits are committed and pushed to the target branch
# (which triggers the WebGL CI build). Turn OFF for a read-only demo.
GIT_PUSH_ENABLED=on

# When "on", a background poller fast-forwards the local checkout from the
# remote so the freshly-built game (docs/game) appears in the preview.
GIT_PULL_ENABLED=on

# How often (seconds) the puller checks for a new build. Min 10.
GAME_PULL_INTERVAL_SEC=30

# Branch the AI commits/pushes to, and that CI builds from. Default: main.
GIT_TARGET_BRANCH=main
GIT_REMOTE=origin

# owner/repo for the working checkout. Used to build the authenticated push URL
# and as a fallback if it can't be parsed from the remote.
GIT_REPO_SLUG=jorgecotillo/csharp_unity_tutoring

# HTTPS URL the container clones on first boot (public repo — no creds needed
# to read). entrypoint.sh uses this to create $REPO_ROOT.
GIT_CLONE_URL=https://github.com/jorgecotillo/csharp_unity_tutoring.git

# Identity stamped on AI commits (the human co-author trailer is added too).
GIT_AUTHOR_NAME=Warren Studio Bot
GIT_AUTHOR_EMAIL=warren-studio-bot@users.noreply.github.com

# ---- GitHub App (LEGACY / optional push fallback) -------------------------
# OPTIONAL. With GitHub OAuth login (above) enabled, the signed-in user's own
# token is used to push, so you do NOT need this. It remains as a fallback push
# credential for unattended machine pushes (when no human OAuth token is present).
#
# If you do use it: create a GitHub App installed on ONLY the
# csharp_unity_tutoring repo with "Contents: write", then provide its App ID,
# the Installation ID, and its private key. The app mints a short-lived
# installation token per push — nothing long-lived is stored.
#
# Leave these blank to disable the fallback (recommended once OAuth is set up).
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Provide the private key ONE of two ways:
#  (a) inline PEM — paste the whole key, with literal \n between lines, OR
#  (b) a path to a mounted .pem file (preferred on Azure: mount from Key Vault).
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE!...\n-----END RSA PRIVATE KEY-----\n"
# GITHUB_APP_PRIVATE_KEY_PATH=/home/secrets/warren-studio.pem
